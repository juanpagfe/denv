#!/bin/bash

# wlog - Manage work log and tickets currently being worked on.

WLOG_DIR="$HOME/Work/wlog"
LOG_FILE="$WLOG_DIR/wlog.log"
EDITOR="${EDITOR:-vim}"

mkdir -p "$WLOG_DIR"
touch "$LOG_FILE"

usage() {
    echo "Usage: $(basename "$0") [option] [args]"
    echo "Options:"
    echo "  -n, --new <filename>     Create a new markdown context file in $WLOG_DIR"
    echo "  -l, --list               List the current files in the archive"
    echo "  -s, --save <filename>    Move the file into $WLOG_DIR (asks for a comment)"
    echo "      --load [filename]    Copy a context file from the archive into the current directory (interactive picker if omitted)"
    echo "  -r, --remove [filename]  Remove a file from the archive (interactive picker if omitted)"
    echo "  -e, --edit [filename]    Edit a file from the archive in \$EDITOR ($EDITOR) (interactive picker if omitted)"
    echo "      --show [filename]    Show a context file (interactive picker if omitted)"
    echo "  -g, --grep <pattern>     Search log entries and context files for a pattern"
    echo "      --print              Print all logs"
    echo "      --today              With --print: show only today's log entries"
    echo "      --since <date>       With --print: show entries since <date> (e.g. '2026-05-01', 'yesterday', '3 days ago')"
    echo "  -m, --message <message>  Write a new log entry with the given message"
    echo "  -h, --help               Show this help message"
    exit 1
}

timestamp() {
    date "+%Y-%m-%d %H:%M:%S"
}

log_entry() {
    local message="$1"
    echo "[$(timestamp)] $message" >> "$LOG_FILE"
}

# Resolves a filename to a path inside WLOG_DIR. Adds .md extension if missing
# and the bare filename does not exist but the .md variant does.
resolve_archive_path() {
    local filename="$1"
    local target="$WLOG_DIR/$filename"
    if [[ ! -f "$target" && -f "${target}.md" ]]; then
        target="${target}.md"
    fi
    echo "$target"
}

# Interactively pick a context file from the archive.
# Usage: pick_archive_file <action_word>   (e.g. "show", "edit", "remove", "load")
# Echoes the absolute path of the chosen file, or returns non-zero if nothing
# is available / the user aborts.
pick_archive_file() {
    local action="${1:-use}"
    local files=()
    while IFS= read -r -d '' file; do
        files+=("$file")
    done < <(find "$WLOG_DIR" -maxdepth 1 -type f ! -name "$(basename "$LOG_FILE")" -print0 | sort -z)

    if [ ${#files[@]} -eq 0 ]; then
        echo "No context files in $WLOG_DIR." >&2
        return 1
    fi

    echo "Select a file to ${action}:" >&2
    local names=()
    for f in "${files[@]}"; do
        names+=("$(basename "$f")")
    done

    local choice
    select choice in "${names[@]}"; do
        if [[ -n "$choice" ]]; then
            echo "$WLOG_DIR/$choice"
            return 0
        else
            echo "Invalid selection." >&2
        fi
    done
    return 1
}

new_context() {
    local filename="$1"

    if [[ -z "$filename" ]]; then
        echo "Error: a filename is required."
        usage
    fi

    # Ensure .md extension
    [[ "$filename" != *.md ]] && filename="${filename}.md"

    local target="$WLOG_DIR/$filename"

    if [[ -f "$target" ]]; then
        echo "File '$filename' already exists. Skipping creation."
        log_entry "Context '$filename' already existed (no creation)."
    else
        : > "$target"
        echo "Created new context file: $target"
        log_entry "New context created: '$filename'."
    fi
}

list_files() {
    local files=()
    while IFS= read -r -d '' file; do
        files+=("$file")
    done < <(find "$WLOG_DIR" -maxdepth 1 -type f ! -name "$(basename "$LOG_FILE")" -print0)

    if [ ${#files[@]} -eq 0 ]; then
        echo "No context files in $WLOG_DIR."
        return
    fi

    printf "%-40s | %-20s\n" "Filename" "Modified"
    echo "---------------------------------------------------------------------"

    for file in "${files[@]}"; do
        fname=$(basename "$file")
        mtime=$(date -r "$file" "+%Y-%m-%d %H:%M:%S")
        printf "%-40s | %-20s\n" "$fname" "$mtime"
    done
}

save_file() {
    local filepath="$1"

    if [[ -z "$filepath" ]]; then
        echo "Error: a filename is required."
        usage
    fi

    filepath="${filepath/#\~/$HOME}"

    if [[ ! -f "$filepath" ]]; then
        echo "Error: File '$filepath' not found."
        exit 1
    fi

    local fname
    fname=$(basename "$filepath")
    local target="$WLOG_DIR/$fname"

    read -r -p "Enter a comment for '$fname': " COMMENT

    mv "$filepath" "$target"
    echo "Moved '$fname' to $WLOG_DIR"

    if [[ -n "$COMMENT" ]]; then
        log_entry "Saved file '$fname': $COMMENT"
    else
        log_entry "Saved file '$fname'."
    fi
}

load_file() {
    local filename="$1"
    local source

    if [[ -n "$filename" ]]; then
        source=$(resolve_archive_path "$filename")
        if [[ ! -f "$source" ]]; then
            echo "Error: File '$filename' not found in $WLOG_DIR."
            exit 1
        fi
    else
        source=$(pick_archive_file "load") || exit 0
    fi

    local fname
    fname=$(basename "$source")
    local target="$PWD/$fname"

    if [[ -e "$target" ]]; then
        read -r -p "'$fname' already exists in $PWD. Overwrite? [y/N]: " CONFIRM
        case "$CONFIRM" in
            [yY]|[yY][eE][sS]) ;;
            *) echo "Aborted."; exit 0 ;;
        esac
    fi

    cp "$source" "$target"
    echo "Loaded '$fname' into $PWD"
    log_entry "Loaded file '$fname' into '$PWD'."
}

remove_file() {
    local filename="$1"
    local target

    if [[ -n "$filename" ]]; then
        target=$(resolve_archive_path "$filename")
        if [[ ! -f "$target" ]]; then
            echo "Error: File '$filename' not found in $WLOG_DIR."
            exit 1
        fi
    else
        target=$(pick_archive_file "remove") || exit 0
    fi

    read -r -p "Are you sure you want to remove '$(basename "$target")'? [y/N]: " CONFIRM
    case "$CONFIRM" in
        [yY]|[yY][eE][sS])
            rm -f "$target"
            echo "Removed '$(basename "$target")'."
            log_entry "Removed file '$(basename "$target")'."
            ;;
        *)
            echo "Aborted."
            ;;
    esac
}

edit_file() {
    local filename="$1"
    local target

    if [[ -n "$filename" ]]; then
        target=$(resolve_archive_path "$filename")

        # If file doesn't exist, default to opening a new .md context
        if [[ ! -f "$target" ]]; then
            [[ "$filename" != *.md ]] && filename="${filename}.md"
            target="$WLOG_DIR/$filename"
            : > "$target"
            log_entry "New context created via edit: '$(basename "$target")'."
        fi
    else
        target=$(pick_archive_file "edit") || exit 0
    fi

    "$EDITOR" "$target"
    log_entry "Edited file '$(basename "$target")'."
}

print_logs() {
    local since="$1"

    if [ ! -s "$LOG_FILE" ]; then
        echo "No log entries yet."
        return
    fi

    if [[ -z "$since" ]]; then
        cat "$LOG_FILE"
        return
    fi

    # Convert the user-provided date into an epoch.
    # If the argument looks like a bare date (YYYY-MM-DD), anchor it to start of day.
    local since_epoch
    if [[ "$since" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
        since_epoch=$(date -d "$since 00:00:00" "+%s" 2>/dev/null)
    else
        since_epoch=$(date -d "$since" "+%s" 2>/dev/null)
    fi

    if [[ -z "$since_epoch" ]]; then
        echo "Error: could not parse date '$since'."
        exit 1
    fi

    # Read each log line, parse the leading [YYYY-MM-DD HH:MM:SS] timestamp,
    # convert to epoch, and print if it's at or after the cutoff.
    local line stamp ts
    while IFS= read -r line; do
        # Match leading "[YYYY-MM-DD HH:MM:SS]"
        if [[ "$line" =~ ^\[([0-9]{4}-[0-9]{2}-[0-9]{2})\ ([0-9]{2}:[0-9]{2}:[0-9]{2})\] ]]; then
            stamp="${BASH_REMATCH[1]} ${BASH_REMATCH[2]}"
            ts=$(date -d "$stamp" "+%s" 2>/dev/null)
            [[ -n "$ts" && "$ts" -ge "$since_epoch" ]] && printf '%s\n' "$line"
        fi
    done < "$LOG_FILE"
}

show_file() {
    local filename="$1"
    local target

    if [[ -n "$filename" ]]; then
        target=$(resolve_archive_path "$filename")
        if [[ ! -f "$target" ]]; then
            echo "Error: File '$filename' not found in $WLOG_DIR."
            exit 1
        fi
    else
        target=$(pick_archive_file "show") || exit 0
    fi

    echo "----- $(basename "$target") -----"
    if [[ -s "$target" ]]; then
        cat "$target"
    else
        echo "(empty file)"
    fi
}

grep_all() {
    local pattern="$1"

    if [[ -z "$pattern" ]]; then
        echo "Error: a pattern is required."
        usage
    fi

    local found=0

    if [[ -s "$LOG_FILE" ]]; then
        local log_matches
        log_matches=$(grep -n -- "$pattern" "$LOG_FILE" 2>/dev/null)
        if [[ -n "$log_matches" ]]; then
            echo "===== $(basename "$LOG_FILE") ====="
            echo "$log_matches"
            echo
            found=1
        fi
    fi

    while IFS= read -r -d '' file; do
        local matches
        matches=$(grep -n -- "$pattern" "$file" 2>/dev/null)
        if [[ -n "$matches" ]]; then
            echo "===== $(basename "$file") ====="
            echo "$matches"
            echo
            found=1
        fi
    done < <(find "$WLOG_DIR" -maxdepth 1 -type f ! -name "$(basename "$LOG_FILE")" -print0)

    if [[ $found -eq 0 ]]; then
        echo "No matches for '$pattern'."
    fi
}

write_message() {
    local message="$1"

    if [[ -z "$message" ]]; then
        echo "Error: a message is required."
        usage
    fi

    log_entry "$message"
    echo "Log entry added."
}

if [ $# -eq 0 ]; then
    usage
fi

case "$1" in
    -n|--new)
        new_context "$2"
        ;;
    -l|--list)
        list_files
        ;;
    -s|--save)
        save_file "$2"
        ;;
    --load)
        load_file "$2"
        ;;
    -r|--remove)
        remove_file "$2"
        ;;
    -e|--edit)
        edit_file "$2"
        ;;
    --show)
        show_file "$2"
        ;;
    -g|--grep)
        grep_all "$2"
        ;;
    --print)
        SINCE=""
        shift
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --today)
                    SINCE=$(date "+%Y-%m-%d")
                    shift
                    ;;
                --since)
                    if [[ -z "$2" ]]; then
                        echo "Error: --since requires a date argument."
                        usage
                    fi
                    SINCE="$2"
                    shift 2
                    ;;
                *)
                    echo "Invalid option for --print: $1"
                    usage
                    ;;
            esac
        done
        print_logs "$SINCE"
        ;;
    -m|--message)
        shift
        MESSAGE=""
        while [[ $# -gt 0 && ! "$1" =~ ^- ]]; do
            MESSAGE+="$1 "
            shift
        done
        # Trim trailing space
        MESSAGE="${MESSAGE% }"
        write_message "$MESSAGE"
        ;;
    -h|--help)
        usage
        ;;
    *)
        echo "Invalid option: $1"
        usage
        ;;
esac
